{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Job Posting",
  "type": "object",
  "required": ["job_title", "company", "location"],
  "properties": {
    "job_title": {"type": "string"},
    "company": {"type": "string"},
    "location": {"type": "string"},
    "salary_min": {"type": "number", "minimum": 0},
    "salary_max": {"type": "number", "minimum": 0},
    "employment_type": {"type": "string", "enum": ["full-time", "part-time", "contract", "internship"]},
    "remote": {"type": "boolean"},
    "required_skills": {"type": "array", "items": {"type": "string"}},
    "experience_years": {"type": "integer", "minimum": 0}
  },
  "additionalProperties": false
}
